  /* ============ Render ============ */
  var STATE = { R: null };
  function n(v) { return (v || 0).toLocaleString('pt-PT'); }
  function worst(inds, R) {
    var order = ['crit', 'warn', 'info'];
    for (var i = 0; i < order.length; i++)
      for (var j = 0; j < inds.length; j++)
        if (inds[j].sev === order[i] && (R[inds[j].id] ? R[inds[j].id].count : 0) > 0) return order[i];
    return 'ok';
  }
  function critTotal(R) {
    var c = 0;
    DIMS.forEach(function (d) { d.inds.forEach(function (i) { if (i.sev === 'crit') c += (R[i.id] ? R[i.id].count : 0); }); });
    return c;
  }

  function renderAll() {
    var R = STATE.R, T = R._totais || {};
    var conf = T.total ? Math.round((1 - (T.problema || 0) / T.total) * 100) : 0;
    var kp = '' +
      kpi('Total de leitores', n(T.total), n(T.ativos) + ' ativos · ' + n(T.inativos) + ' inativos', false) +
      kpi('Com pelo menos 1 problema', n(T.problema), (T.total ? Math.round((T.problema || 0) / T.total * 1000) / 10 : 0) + '% do total', true) +
      kpiBar('Taxa de conformidade', conf + '%', conf) +
      kpi('Situações críticas', n(critTotal(R)), 'exigem ação imediata', true);

    var cards = DIMS.map(function (dim) {
      var ws = worst(dim.inds, R), tot = 0;
      var rows = dim.inds.map(function (i) {
        var o = R[i.id] || { count: 0 }, c = o.count || 0; tot += c;
        var cls = c === 0 ? 'ok' : i.sev;
        var nd = o.needs ? '<span class="nd" title="requer dados adicionais">i</span>' : '';
        return '<div class="ind" data-id="' + i.id + '" title="' + i.d + '">' +
          '<span class="s x-' + (c === 0 ? 'ok' : i.sev) + '"></span>' +
          '<span class="n">' + i.n + '</span>' + nd +
          '<span class="ct c-' + cls + '">' + n(c) + '</span></div>';
      }).join('');
      return '<section class="dim"><h3><span class="dot x-' + ws + '"></span>' + dim.icon + ' ' + dim.t +
        '<span class="c">' + n(tot) + '</span></h3>' + rows + '</section>';
    }).join('');

    document.getElementById('bmo-dq-body').innerHTML =
      '<div class="kpis">' + kp + '</div><div class="grid">' + cards + '</div>';
    Array.prototype.forEach.call(document.querySelectorAll('#bmo-dq .ind'), function (el) {
      el.onclick = function () { openDrawer(el.getAttribute('data-id')); };
    });
  }
  function kpi(k, v, s, alert) {
    return '<div class="kpi' + (alert ? ' alert' : '') + '"><div class="k">' + k + '</div><div class="v">' + v + '</div><div class="s">' + s + '</div></div>';
  }
  function kpiBar(k, v, pct) {
    return '<div class="kpi"><div class="k">' + k + '</div><div class="v">' + v + '</div><div class="bar"><i style="width:' + pct + '%"></i></div></div>';
  }

  /* ============ Gaveta de detalhe ============ */
  function findInd(id) { for (var a = 0; a < DIMS.length; a++) for (var b = 0; b < DIMS[a].inds.length; b++) if (DIMS[a].inds[b].id === id) return DIMS[a].inds[b]; return null; }
  function pname(p) { return ((p.surname || '') + ', ' + (p.firstname || '')).replace(/^, |, $/, ''); }
  function plink(p) { return '/cgi-bin/koha/members/moremember.pl?borrowernumber=' + (p.patron_id != null ? p.patron_id : ''); }
  function openDrawer(id) {
    var ind = findInd(id), o = (STATE.R[id]) || { count: 0 };
    document.getElementById('bmo-dq-dr-t').textContent = ind ? ind.n : 'Registos';
    document.getElementById('bmo-dq-dr-s').textContent = n(o.count) + ' registos' + (o.needs ? ' · requer dados adicionais' : '');
    var html;
    if (o.needs) {
      html = '<p style="font-size:12.5px;color:#6b6b6b">Este indicador necessita de dados que não vêm no objeto base de /api/v1/patrons (circulação, relações de garante) ou de pré-cálculo periódico. A lista será preenchida quando essa fonte estiver ligada.</p>';
    } else if (o.groups) {
      html = '<table><thead><tr><th>Cartão</th><th>Nome</th><th>Email</th><th>Telefone</th></tr></thead><tbody>';
      o.groups.forEach(function (g) {
        html += '<tr class="gh"><td colspan="4">' + g._group.replace(/\|/g, ' · ') + ' (' + g.rows.length + ')</td></tr>';
        g.rows.forEach(function (p) {
          html += '<tr><td><a href="' + plink(p) + '">' + (p.cardnumber || '') + '</a></td><td>' + pname(p) + '</td><td>' + (p.email || '') + '</td><td>' + (p.mobile || p.phone || '') + '</td></tr>';
        });
      });
      html += '</tbody></table>';
    } else {
      var rows = (o.sample || []);
      html = '<table><thead><tr><th>Cartão</th><th>Nome</th><th>Valor relevante</th></tr></thead><tbody>' +
        (rows.length ? rows.map(function (p) {
          return '<tr><td><a href="' + plink(p) + '">' + (p.cardnumber || '') + '</a></td><td>' + pname(p) + '</td><td>' + detail(id, p) + '</td></tr>';
        }).join('') : '<tr><td colspan="3" style="color:#6b6b6b">Sem registos para mostrar.</td></tr>') +
        '</tbody></table>';
    }
    document.getElementById('bmo-dq-dr-b').innerHTML = html;
    document.getElementById('bmo-dq-dr').classList.add('open');
    document.getElementById('bmo-dq-scrim').style.display = 'block';
  }
  function detail(id, p) {
    switch (id) {
      case 'email_mal': return p.email || '';
      case 'tel_inv': return (p.mobile || p.phone || '');
      case 'cp_inv': return p.postal_code || '';
      case 'dn_inv': return (p.date_of_birth || '') + ' (idade ' + (ageOf(p.date_of_birth) == null ? '?' : ageOf(p.date_of_birth)) + ')';
      case 'freg_inv': return 'sort1 = "' + (p[CONFIG.fields.freguesia] || '') + '"';
      case 'sem_freguesia': return '(vazio)';
      default: return (p.email || p.mobile || p.phone || p.city || '');
    }
  }
  function closeDrawer() {
    document.getElementById('bmo-dq-dr').classList.remove('open');
    document.getElementById('bmo-dq-scrim').style.display = 'none';
  }

  /* ============ Resultados de demonstração ============ */
  function demoResults() {
    var R = { _totais: DEMO._totais };
    DIMS.forEach(function (d) { d.inds.forEach(function (i) {
      var needs = ['dup_fuzzy', 'idade_cat', 'sem_mov', 'rgpd_menor'].indexOf(i.id) > -1;
      R[i.id] = { count: DEMO[i.id] || 0, needs: needs, sample: [] };
    }); });
    return R;
  }

  /* ============ Arranque ============ */
  function shell(host) {
    var wrap = document.createElement('div');
    wrap.id = 'bmo-dq';
    wrap.innerHTML =
      '<div class="hd"><div><h2>Qualidade dos dados — Leitores</h2><div class="meta" id="bmo-dq-meta"></div></div>' +
      '<div><button class="btn" id="bmo-dq-csv">Exportar CSV</button> <button class="btn pri" id="bmo-dq-reload">Reanalisar</button></div></div>' +
      '<div class="status" id="bmo-dq-status"></div><div id="bmo-dq-body"></div>';
    host.insertBefore(wrap, host.firstChild);

    var scrim = document.createElement('div'); scrim.id = 'bmo-dq-scrim';
    var dr = document.createElement('aside'); dr.id = 'bmo-dq-dr';
    dr.innerHTML = '<div class="h"><div><b id="bmo-dq-dr-t">—</b><span id="bmo-dq-dr-s">—</span></div><button id="bmo-dq-dr-x">×</button></div><div class="b" id="bmo-dq-dr-b"></div>';
    document.body.appendChild(scrim); document.body.appendChild(dr);
    scrim.onclick = closeDrawer;
    document.getElementById('bmo-dq-dr-x').onclick = closeDrawer;
    document.getElementById('bmo-dq-reload').onclick = function () { boot(true); };
    document.getElementById('bmo-dq-csv').onclick = exportCSV;
  }
  function setStatus(t) { var el = document.getElementById('bmo-dq-status'); if (el) el.textContent = t || ''; }
  function setMeta(R) {
    var el = document.getElementById('bmo-dq-meta');
    if (el) el.textContent = (R._totais.total || 0).toLocaleString('pt-PT') + ' leitores analisados · ' +
      (CONFIG.useDemoData ? 'dados de demonstração' : 'REST API') + ' · ' + new Date().toLocaleString('pt-PT');
  }
  function exportCSV() {
    var R = STATE.R; if (!R) return;
    var lines = ['dimensao;indicador;severidade;contagem'];
    DIMS.forEach(function (d) { d.inds.forEach(function (i) {
      lines.push([d.t, i.n, i.sev, (R[i.id] ? R[i.id].count : 0)].join(';'));
    }); });
    var blob = new Blob(['\uFEFF' + lines.join('\n')], { type: 'text/csv;charset=utf-8' });
    var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
    a.download = 'qualidade_leitores.csv'; a.click();
  }

  function boot(reloaded) {
    injectCSS();
    if (!document.getElementById('bmo-dq')) {
      var host = document.querySelector(CONFIG.mount) || document.body;
      shell(host);
    }
    if (CONFIG.useDemoData) {
      STATE.R = demoResults(); setMeta(STATE.R); setStatus(''); renderAll();
      return;
    }
    setStatus('A obter leitores da REST API...');
    fetchAll(function (got, total) { setStatus('A obter leitores... ' + got + (total ? ' / ' + total : '')); })
      .then(function (patrons) {
        STATE.R = analyze(patrons); setMeta(STATE.R); setStatus(''); renderAll();
      })
      .catch(function (err) { setStatus('Erro ao obter dados: ' + err.message); });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', function () { boot(); });
  else boot();
})();
