  /* ============ Verificações deterministas ============ */
  function ageOf(dob) {
    if (!dob) return null;
    var d = new Date(dob); if (isNaN(d)) return null;
    var t = new Date(), a = t.getFullYear() - d.getFullYear();
    var m = t.getMonth() - d.getMonth();
    if (m < 0 || (m === 0 && t.getDate() < d.getDate())) a--;
    return a;
  }
  function emailBad(e) {
    if (!e) return false; e = String(e).trim();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(e)) return true;
    return /(\.con\b|\.cmo\b|hotmal|gmial|gmai\.|outlok)/i.test(e);
  }
  function phoneBad(p) {
    if (!p) return false;
    var d = String(p).replace(/[\s\-.()]/g, '').replace(/^\+351/, '');
    if (!/^\d{9}$/.test(d)) return true;
    if (/^(\d)\1{8}$/.test(d)) return true;
    return d === '123456789';
  }
  function postalBad(cp) { return cp ? !/^\d{4}-\d{3}$/.test(String(cp).trim()) : false; }
  function dobBad(dob) {
    if (!dob) return false;
    var d = new Date(dob); if (isNaN(d)) return true;
    if (d > new Date()) return true;
    var a = ageOf(dob);
    return a === null || a < 0 || a > CONFIG.maxAgeYears;
  }
  function fregBad(v) {
    if (v == null || v === '') return false;
    return FREG_VALID.indexOf(String(v).trim()) === -1;
  }
  function capsBad(s) {
    if (!s) return false;
    var L = String(s).replace(/[^A-Za-zÀ-ÿ]/g, '');
    if (L.length < 2) return false;
    return L === L.toUpperCase() || L === L.toLowerCase();
  }
  function spaceBad(s) { return s == null ? false : (s !== String(s).trim() || /\s{2,}/.test(s)); }
  function phBad(s) {
    if (!s) return false;
    var t = String(s).trim().toLowerCase();
    return /^(teste|test|xxx+|asdf|nome|sn|s\/n|\.|-)$/.test(t) || /^(.)\1+$/.test(t.replace(/\s/g, ''));
  }
  function isInactive(p) {
    var ex = p[CONFIG.fields.expiry];
    return ex ? new Date(ex) < new Date() : false;
  }

  /* ============ Análise sobre os leitores ============ */
  function analyze(patrons) {
    var R = {}, flagged = {};
    function add(id, p, crit) {
      if (!R[id]) R[id] = { count: 0, sample: [] };
      R[id].count++;
      if (R[id].sample.length < 80) R[id].sample.push(p);
      if (p && p.patron_id != null) flagged[p.patron_id] = 1;
    }
    var byName = {}, byEmail = {}, byPhone = {}, ativos = 0, inativos = 0;
    var now = new Date();
    var y3 = new Date(); y3.setFullYear(now.getFullYear() - 3);
    var in30 = new Date(); in30.setDate(now.getDate() + 30);

    patrons.forEach(function (p) {
      if (isInactive(p)) inativos++; else ativos++;

      if (!(p.email || p.phone || p.mobile || p.address)) add('sem_contacto', p);
      if (!p[CONFIG.fields.expiry]) add('sem_validade', p);

      var freg = p[CONFIG.fields.freguesia];
      if (freg == null || freg === '') add('sem_freguesia', p);
      else if (fregBad(freg)) add('freg_inv', p);

      if (emailBad(p.email)) add('email_mal', p);
      if (phoneBad(p.phone) || phoneBad(p.mobile)) add('tel_inv', p);
      if (postalBad(p.postal_code)) add('cp_inv', p);
      if (dobBad(p.date_of_birth)) add('dn_inv', p);
      if (phBad(p.firstname) || phBad(p.surname)) add('placeholder', p);
      if ((p.phone && /@/.test(p.phone)) || /@/.test(p.surname || '') || /@/.test(p.firstname || '')) add('trocados', p);
      if (capsBad(p.surname) || capsBad(p.firstname)) add('caps', p);
      if (spaceBad(p.surname) || spaceBad(p.firstname) || spaceBad(p.email)) add('espacos', p);

      var ex = p[CONFIG.fields.expiry];
      if (ex) {
        var de = new Date(ex);
        if (de < y3) {
          add('exp_3a', p);
          if (p.email || p.phone || p.address || p.date_of_birth) add('rgpd_ret', p);
        }
        if (de >= now && de <= in30) add('exp_30d', p);
      }
      if (p.privacy == null) add('rgpd_priv', p);

      var nk = ((p.surname || '') + '|' + (p.firstname || '') + '|' + (p.date_of_birth || '')).toLowerCase().trim();
      (byName[nk] || (byName[nk] = [])).push(p);
      if (p.email) { var ek = p.email.toLowerCase().trim(); (byEmail[ek] || (byEmail[ek] = [])).push(p); }
      var ph = (p.mobile || p.phone || '').replace(/\D/g, '');
      if (ph) (byPhone[ph] || (byPhone[ph] = [])).push(p);
    });

    function dups(map) {
      var c = 0, g = [];
      Object.keys(map).forEach(function (k) {
        if (map[k].length > 1) {
          c += map[k].length;
          map[k].forEach(function (p) { if (p.patron_id != null) flagged[p.patron_id] = 1; });
          if (g.length < 60) g.push({ _group: k, rows: map[k] });
        }
      });
      return { count: c, groups: g };
    }
    var dn = dups(byName), dei = dups(byEmail), dpi = dups(byPhone);
    R.dup_nome = { count: dn.count, groups: dn.groups };
    R.dup_email = { count: dei.count, groups: dei.groups };
    R.dup_tel = { count: dpi.count, groups: dpi.groups };

    ['dup_fuzzy', 'idade_cat', 'sem_mov', 'rgpd_menor'].forEach(function (id) {
      if (!R[id]) R[id] = { count: 0, needs: true };
    });

    R._totais = { total: patrons.length, ativos: ativos, inativos: inativos, problema: Object.keys(flagged).length };
    return R;
  }

  /* ============ Obtenção via REST API (paginada) ============ */
  function fetchAll(onProgress) {
    var out = [];
    function page(p) {
      var url = CONFIG.apiBase + '?_page=' + p + '&_per_page=' + CONFIG.pageSize;
      return fetch(url, { headers: { Accept: 'application/json' }, credentials: 'same-origin' })
        .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); 
          return r.json().then(function (d) { return { d: d, total: parseInt(r.headers.get('X-Total-Count') || '0', 10) }; }); })
        .then(function (res) {
          out = out.concat(res.d);
          if (onProgress) onProgress(out.length, res.total);
          if (res.d.length === CONFIG.pageSize && out.length < res.total && p < 500) return page(p + 1);
          return out;
        });
    }
    return page(1);
  }

